# Public — used by browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Used to build customer-site URLs in QR code page
NEXT_PUBLIC_CUSTOMER_SITE_URL=https://beneficial-charm-production-d3c1.up.railway.app

# Server-only — required for the admin "Team & logins" page (create/delete logins).
# Use the same service_role key the backend uses. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
